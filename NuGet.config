<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageManagement>
    <!-- Default to patch updates only to avoid major version jumps -->
    <add key="defaultPushSource" value="https://api.nuget.org/v3/index.json" />
  </packageManagement>
  <config>
    <!-- Require explicit version when adding packages to avoid version mismatches -->
    <add key="dependencyVersion" value="Highest" />
  </config>
</configuration>
